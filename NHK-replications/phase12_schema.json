{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 1+2 combined result",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "results"],
  "properties": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_selection",
        "outcome_definition",
        "treatment_definition",
        "model_specification_line"
      ],
      "properties": {
        "sample_selection": {
          "type": "array",
          "items": {"type": "string"}
        },
        "outcome_definition": {"type": "string"},
        "treatment_definition": {"type": "string"},
        "model_specification_line": {"type": "string"}
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["point_estimate", "standard_error", "sample_size"],
      "properties": {
        "point_estimate": {"type": "number"},
        "standard_error": {"type": "number"},
        "sample_size": {"type": "number"}
      }
    }
  }
}
