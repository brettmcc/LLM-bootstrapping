    "birthqtr in {1, 2, 3, 4}",
    "hispan == 1",
    "bpl == 200",
    "citizen == 3",
    "yrimmig > 0 and yrimmig <= year",
    "empstat in {1, 2, 3}",
    "perwt > 0"
  ],
  "treatment_definition": "((yrimmig <= 2007) & ((yrimmig - birthyr) <= 15) & ((birthyr > 1981) | ((birthyr == 1981) & (birthqtr >= 3))))"
