{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM research specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_selection",
    "outcome_definition",
    "treatment_definition",
    "model_specification_line"
  ],
  "properties": {
    "sample_selection": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcome_definition": {
      "type": "string"
    },
    "treatment_definition": {
      "type": "string"
    },
    "model_specification_line": {
      "type": "string"
    }
  }
}
