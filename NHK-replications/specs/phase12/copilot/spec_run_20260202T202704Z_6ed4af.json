{
  "model_specification_line": "model = smf.wls(\"full_time ~ daca_eligible + C(year) + C(statefip)\", data=df, weights=df[\"perwt\"])",
  "outcome_definition": "((empstat == 1) & uhrswork.between(35, 99)).astype(float)",
  "sample_selection": [
    "year between 2013 and 2016 (inclusive)",
    "perwt > 0 and statefip > 0",
    "bpl == 200 (Mexico birthplace)",
    "hispan == 1 or hispand in {100, 102, 103, 104, 105, 106, 107}",
    "citizen == 3 (noncitizen as of census)",
    "birthyr between 1982 and 1996 and yrimmig between 1980 and 2012",
    "arrival_age = yrimmig - birthyr <= 15"
  ],
  "treatment_definition": "((birthyr.between(1982, 1996)) & ((yrimmig - birthyr) <= 15) & (yrimmig <= 2007)).astype(float)"
}