{
  "model_specification_line": "model = smf.ols('full_time ~ daca_eligible + C(year)', data=sample).fit(cov_type='HC1')",
  "outcome_definition": "full_time = uhrswork >= 35",
  "sample_selection": [
    "year between 2013 and 2016",
    "hispan == 1 and bpl == 200",
    "citizen == 3 (foreign-born noncitizen)",
    "age >= 18",
    "birthyr >= 1982",
    "yrimmig > 0 and yrimmig >= birthyr",
    "0 <= uhrswork <= 98"
  ],
  "treatment_definition": "daca_eligible = (yrimmig <= 2007) & ((yrimmig - birthyr) <= 15) & (birthyr >= 1982)"
}