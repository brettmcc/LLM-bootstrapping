{
  "model_specification_line": "model = smf.wls(\"full_time ~ eligible\", data=df, weights=df[\"perwt\"]).fit(cov_type=\"HC3\")",
  "outcome_definition": "(uhrswork >= 35)",
  "sample_selection": [
    "year between 2013 and 2016 (post-DACA period)",
    "age between 18 and 40 (arrived before turning 31 in 2012)",
    "hispan == 1 (Hispanic general code)",
    "bpl == 200 (born in Mexico)",
    "citizen == 3 (not a citizen)",
    "perwt > 0 (positive person weight)",
    "birthyr between 1975 and 1997 (aligns with DACA birth window)",
    "yrimmig between 1 and 2007 (arrived before the 2007 continuous residency cutoff)"
  ],
  "treatment_definition": "(birthyr.between(1982, 1997) & (yrimmig <= 2007) & (yrimmig - birthyr).between(0, 15))"
}