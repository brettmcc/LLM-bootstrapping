{
  "model_specification_line": "model = smf.wls(\"full_time ~ daca_eligible + C(year)\", data=analysis_df, weights=analysis_df[\"perwt\"]).fit(cov_type=\"HC1\")",
  "outcome_definition": "(labforce == 1) & (uhrswork >= 35)",
  "sample_selection": [
    "year between 2013 and 2016",
    "hispan == 1 and bpl == 200 (Mexican-born Hispanic respondents)",
    "yrimmig > 0, yrimmig <= 2012, birthyr between 1982 and 1997, and citizen >= 2 to approximate noncitizens",
    "perwt > 0 to keep positive person weights for the weighted regression"
  ],
  "treatment_definition": "(yrimmig > 0) & (yrimmig <= 2007) & ((yrimmig - birthyr) <= 15) & ((2012 - birthyr) >= 15) & ((2012 - birthyr) <= 30) & (citizen >= 2)"
}