{
  "model_specification_line": "model = smf.ols(\"full_time ~ dac_elig\", data=df).fit()",
  "outcome_definition": "full_time = (uhrswork.where(uhrswork < 96).fillna(0) >= 35).astype(int)",
  "sample_selection": [
    "year >= 2013 and year <= 2016",
    "hispan == 1",
    "bpl == 200",
    "citizen == 2",
    "birthyr >= 1982 and birthyr <= 1997",
    "yrimmig > 0 and yrimmig <= 2012"
  ],
  "treatment_definition": "dac_elig = ((yrimmig <= 2007) & ((yrimmig - birthyr) < 16))"
}