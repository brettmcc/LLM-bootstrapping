{
  "model_specification_line": "smf.wls(\"full_time ~ treatment + C(year)\", data=sample, weights=sample[\"perwt\"]).fit(cov_type=\"HC1\")",
  "outcome_definition": "full_time = (empstat == 1) & (uhrswork >= 35)",
  "sample_selection": [
    "2013 <= year <= 2016",
    "hispan == 1 (Mexican origin)",
    "bpl == 200 (Mexico)",
    "citizen in [0, 1] (noncitizen or naturalized)",
    "yrimmig > 0",
    "perwt > 0"
  ],
  "treatment_definition": "treatment = (birthyr >= 1982) & (yrimmig <= birthyr + 15) & (yrimmig <= 2007)"
}