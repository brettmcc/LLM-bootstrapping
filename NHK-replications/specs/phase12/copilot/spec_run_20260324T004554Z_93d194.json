    "age between 18 and 45",
    "uhrswork between 0 and 99",
    "yrimmig between 1 and 2016",
    "imm_age = yrimmig - birthyr between 0 and 80"
  ],
  "treatment_definition": "daca_eligible = (birthyr >= 1982) & (birthyr <= 1997) & (yrimmig <= 2007) & ((yrimmig - birthyr) < 16)"
