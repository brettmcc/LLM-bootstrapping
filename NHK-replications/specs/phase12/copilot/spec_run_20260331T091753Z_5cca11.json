{
  "model_specification_line": "model = smf.wls(\"full_time_employed ~ treated + treated_post + age2012 + I(age2012 ** 2) + C(sex) + C(marst) + C(state_year)\", data=analysis_df, weights=analysis_df[\"perwt\"]).fit(cov_type=\"cluster\", cov_kwds={\"groups\": analysis_df[\"statefip\"]})",
  "outcome_definition": "((df[\"empstat\"] == 1) & (df[\"uhrswork\"] >= 35)).astype(int)",
  "sample_selection": [
    "df[\"year\"].isin([2006, 2007, 2008, 2009, 2010, 2011, 2013, 2014, 2015, 2016])",
    "df[\"gq\"].isin([1, 2, 5])",
    "df[\"hispan\"] == 1",
    "df[\"bpl\"] == 200",
    "df[\"citizen\"] == 3",
    "df[\"yrimmig\"] <= 2007",
    "(df[\"yrimmig\"] - df[\"birthyr\"]) < 16",
    "(df[\"age\"] - (df[\"year\"] - 2012)).between(15, 34)",
    "((df[\"school\"] == 2) | (df[\"educd\"] >= 62) | (df[\"vetstat\"] == 2))",
    "df[\"sex\"].isin([1, 2])",
    "df[\"marst\"].isin([1, 2, 3, 4, 5, 6])",
    "df[\"empstat\"].isin([1, 2, 3])"
  ],
  "treatment_definition": "((df[\"age\"] - (df[\"year\"] - 2012)) <= 30).astype(int)"
}