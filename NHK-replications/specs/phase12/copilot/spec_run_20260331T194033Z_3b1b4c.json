{
  "model_specification_line": "model = smf.wls(\"full_time_employed ~ treated_post + C(birthyr) + C(state_year) + C(sex) + C(educ)\", data=analysis_df, weights=analysis_df[\"perwt\"]).fit(cov_type=\"cluster\", cov_kwds={\"groups\": analysis_df[\"statefip\"]})",
  "outcome_definition": "((df[\"empstat\"] == 1) & (df[\"uhrswork\"] >= 35)).astype(int)",
  "sample_selection": [
    "(df[\"year\"].between(2006, 2016)) & (df[\"year\"] != 2012)",
    "(df[\"bpl\"] == 200) & (df[\"hispan\"] == 1) & (df[\"citizen\"] == 3)",
    "(df[\"yrimmig\"] > 0) & (df[\"yrimmig\"] <= 2007) & ((df[\"yrimmig\"] - df[\"birthyr\"]) >= 0) & ((df[\"yrimmig\"] - df[\"birthyr\"]) <= 15)",
    "df[\"birthyr\"].between(1979, 1984)",
    "df[\"school\"] != 2"
  ],
  "treatment_definition": "((df[\"birthyr\"] >= 1982) & (df[\"yrimmig\"] <= 2007) & ((df[\"yrimmig\"] - df[\"birthyr\"]) >= 0) & ((df[\"yrimmig\"] - df[\"birthyr\"]) <= 15)).astype(int)"
}