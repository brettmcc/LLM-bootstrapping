{
  "model_specification_line": "model = smf.wls(\"full_time ~ daca_eligible + age + I(age ** 2) + sex_female + C(year) + C(statefip)\", data=sample, weights=sample[\"perwt\"]).fit(cov_type=\"HC1\")",
  "outcome_definition": "((df[\"empstat\"] == 1) & (df[\"uhrswork\"] >= 35)).astype(int)",
  "sample_selection": [
    "2013 <= year <= 2016",
    "hispan == 1",
    "bpl == 200",
    "citizen in (3, 4, 5)",
    "18 <= age <= 45",
    "birthyr > 0",
    "yrimmig > 0",
    "yrimmig >= birthyr",
    "perwt > 0"
  ],
  "treatment_definition": "((df[\"birthyr\"] >= 1982) & (df[\"yrimmig\"] <= 2007) & ((df[\"yrimmig\"] - df[\"birthyr\"]) <= 15)).astype(int)"
}