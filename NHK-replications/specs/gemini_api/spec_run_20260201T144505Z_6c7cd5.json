{
  "sample_selection": [
    "HISPAN == 1",
    "BPL == 200",
    "CITIZEN == 3",
    "YRIMMIG <= 2007",
    "AGE >= 16",
    "AGE <= 36"
  ],
  "outcome_definition": "(df['UHRSWORK'] >= 35).astype(int)",
  "treatment_definition": "((df['AGE'] - (df['YEAR'] - df['YRIMMIG']) < 16) & (df['YEAR'] - df['AGE'] >= 1981) & (df['YEAR'] >= 2013)).astype(int)",
  "model_specification_line": "smf.ols('full_time_emp ~ treatment + I(df[\"AGE\"] - (df[\"YEAR\"] - df[\"YRIMMIG\"]) < 16) + C(YEAR) + C(STATEFIP)', data=df).fit()"
}