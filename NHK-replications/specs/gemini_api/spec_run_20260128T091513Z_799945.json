{
  "sample_selection": [
    "df['BPL'] == 200",
    "df['HISPAN'] == 1",
    "df['CITIZEN'] == 3",
    "df['AGE'] >= 16",
    "df['AGE'] <= 50"
  ],
  "outcome_definition": "((df['EMPSTAT'] == 1) & (df['UHRSWORK'] >= 35)).astype(int)",
  "treatment_definition": "((df['AGE'] - (df['YEAR'] - df['YRIMMIG']) < 16) & (df['AGE'] - (df['YEAR'] - 2012) < 31) & (df['YRIMMIG'] <= 2007)).astype(int)",
  "model_specification_line": "smf.ols('outcome ~ treatment * I(YEAR >= 2012) + AGE + I(AGE**2) + C(SEX) + C(STATEFIP) + C(YEAR)', data=df).fit()"
}