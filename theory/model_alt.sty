\begin{abstract}
Researchers frequently face a large set of defensible analytic choices---sample restrictions, variable construction, model specification, and estimation method---which can be searched to obtain statistically significant results. This paper formalizes the researcher's search problem within a set of ``reasonable'' analyses and embeds it in a selective-publication environment. We characterize the privately optimal search intensity and derive the privately optimal number of replications under a simple acceptance rule based on a meta-analytic test statistic. The model clarifies comparative statics with respect to computational and data-collection costs and connects to literatures on specification searching, the garden of forking paths, publication bias, and mechanism design for credible inference.
\end{abstract}

\section{Setup}

\subsection{Causal target}
Let $(Y,D,X)$ be observed and $U$ unobserved. The structural relation is
\begin{equation}
Y = g(D,X,U;\theta_0).
\end{equation}
The policy-relevant causal parameter is the average causal marginal effect
\begin{equation}
\theta_0 \equiv \mathbb{E}\!\left[\frac{\partial Y}{\partial D}\,\middle|\, \mathrm{do}(D)\right],
\end{equation}
interpretable as a scalar target (e.g., ATE or average marginal effect under interventions).

\subsection{Researcher choice space and ``reasonable'' analyses}
A researcher chooses an analysis plan
\begin{equation}
r = (S,V,M,E) \in \mathcal{R} \equiv \mathcal{S}\times\mathcal{V}\times\mathcal{M}\times\mathcal{E},
\end{equation}
where $S$ are sample restrictions, $V$ variable construction, $M$ specification choices, and $E$ an estimator.
Let $\Omega \subset \mathcal{R}$ denote the set of analyses deemed \emph{reasonable} by community norms and editorial screening. This is the analogue of the ``multiverse'' / ``specification curve'' admissible set \citep{Leamer1978, GelmanLoken2014}.

Index $\omega \in \Omega$ as an \emph{analysis path}. For each $\omega$, the researcher can compute an estimator $\hat\theta_{\omega}$ and standard error $\hat\sigma_{\omega}$ from a dataset of size $n$.

\subsection{Sampling distribution across analysis paths}
The key distinction in this environment is that the choice of $\omega$ may change (i) the estimand relative to $\theta_0$ (through omitted variables, conditioning sets, measurement, etc.) and (ii) the estimator's variance.

We model these two effects via a path-specific bias and standard error.

\begin{assumption}[Asymptotic normality along each path]\label{ass:an}
For each $\omega\in\Omega$,
\begin{equation}
Z_{\omega}\equiv \frac{\hat\theta_{\omega}-\theta_0-b_{\omega}}{\sigma_{\omega}}
\Rightarrow \mathcal{N}(0,1),
\end{equation}
where $b_{\omega}\in\mathbb{R}$ is a path-specific ``specification bias'' (capturing deviations from the policy target induced by $(S,V,M,E)$) and $\sigma_{\omega}>0$ is the asymptotic standard deviation of $\hat\theta_{\omega}$.
\end{assumption}

\begin{assumption}[Random-effects approximation for search]\label{ass:re}
From the researcher's perspective before running analyses, $(b_{\omega},\sigma_{\omega})$ for candidate paths behave like draws from a distribution $G$ supported on a bounded ``reasonable'' set (capturing that $\Omega$ rules out extreme misspecification).
For tractability, assume $\sigma_{\omega}\equiv\sigma$ is constant across $\omega$ and
\begin{equation}
b_{\omega}\stackrel{iid}{\sim}\mathcal{N}(0,\tau^2),
\end{equation}
independent of the sampling noise in $\hat\theta_{\omega}$.
\end{assumption}

Assumption \ref{ass:re} is a reduced-form way to represent ``researcher degrees of freedom'' and specification uncertainty \citep{Leamer1978, GelmanLoken2014}. The normal approximation is not essential but yields closed-form expressions.

Under Assumptions \ref{ass:an}--\ref{ass:re},
\begin{equation}
\hat\theta_{\omega} \,\big|\, b_{\omega}\sim \mathcal{N}(\theta_0+b_{\omega},\,\sigma^2),
\quad
T_{\omega}\equiv \frac{\hat\theta_{\omega}}{\sigma}\sim \mathcal{N}\!\left(\frac{\theta_0+b_{\omega}}{\sigma},\,1\right).
\end{equation}

\subsection{Publication technology}
A journal (or review process) maps submitted results into acceptance probability. A canonical stylization is acceptance based on statistical significance, consistent with evidence of selection on $p$-values and test statistics \citep{AndrewsKasy2019, BrodeurCookHeyes2020}.

\begin{assumption}[Significance-based acceptance]\label{ass:accept}
Conditional on a submitted test statistic $T$, acceptance occurs iff $T\ge c$, where $c>0$ is a threshold (e.g., $c=1.96$ for 5\% two-sided with known $\sigma$, re-interpreted here as a one-sided screen for a directional claim).
\end{assumption}

Let $B>0$ denote the expected payoff from acceptance (reputation, career returns, journal tier), and normalize the payoff from non-acceptance to $0$.

\section{Researcher search over analysis paths}

\subsection{Search protocol}
The researcher may compute multiple paths in $\Omega$ (a ``forking paths'' / ``specification search'' environment \citep{Leamer1978, GelmanLoken2014}). Let $K\in\mathbb{N}$ denote the number of paths attempted. Each attempt costs $c_S>0$ (time, computation, cleaning, rewriting). The researcher observes $(\hat\theta_{\omega_k},T_{\omega_k})$ sequentially and submits the most favorable result.

For tractability, assume the researcher submits the maximum $T$ among tried paths:
\begin{equation}
T^{\max}_K \equiv \max_{k\le K} T_{\omega_k}.
\end{equation}
Acceptance then occurs iff $T^{\max}_K\ge c$.

\subsection{Success probability as a function of $K$}
Let
\begin{equation}
p \equiv \Pr(T_{\omega}\ge c)
\end{equation}
be the per-path probability of exceeding the threshold.

Under Assumptions \ref{ass:an}--\ref{ass:re}, integrating out $b_{\omega}$ yields
\begin{equation}\label{eq:p}
T_{\omega} \sim \mathcal{N}\!\left(\frac{\theta_0}{\sigma},\, 1+\frac{\tau^2}{\sigma^2}\right),
\quad
p = 1-\Phi\!\left(\frac{c-\theta_0/\sigma}{\sqrt{1+\tau^2/\sigma^2}}\right),
\end{equation}
where $\Phi(\cdot)$ is the standard normal CDF.

Assuming independence across tried paths (a common approximation in selection models),
\begin{equation}\label{eq:psucc}
\Pr(T^{\max}_K\ge c) = 1-(1-p)^K.
\end{equation}

\subsection{Optimal number of tried analysis paths}
The researcher's expected utility from trying $K$ paths is
\begin{equation}\label{eq:U_K}
U(K) = B\big[1-(1-p)^K\big] - c_S K.
\end{equation}

\begin{proposition}[Privately optimal search intensity]\label{prop:Kstar}
Suppose $p\in(0,1)$ and treat $K$ as continuous. The unique interior maximizer satisfies
\begin{equation}\label{eq:Kstar_cont}
(1-p)^{K^*} = \frac{c_S}{B(-\ln(1-p))}.
\end{equation}
Equivalently,
\begin{equation}
K^* = \frac{\ln\!\left(\frac{c_S}{B(-\ln(1-p))}\right)}{\ln(1-p)}.
\end{equation}
The integer-optimal solution is $K^{*}_{\mathbb{N}} \in \{\lfloor K^*\rfloor, \lceil K^*\rceil\}$.
Moreover, $K^*$ increases when $c_S$ decreases and when $B$ increases.
\end{proposition}

\begin{remark}
This is the ``max of many draws'' mechanism: holding fixed per-path quality, reducing search frictions increases the probability of finding a significant specification and thus increases privately optimal search. This is consistent with concerns about specification mining in both statistics and econometrics \citep{Leamer1978, GelmanLoken2014, BrodeurCookHeyes2020}.
\end{remark}

\section{Endogenous replication}

This section extends the model by allowing the researcher to purchase additional \emph{replications}---independent datasets drawn from the same population---and to submit evidence aggregated across replications.

\subsection{Replication protocol and meta-analytic test}
Fix an analysis path $\omega$. The researcher can collect $R\in\mathbb{N}$ independent replications (e.g., new samples, or independent waves/contexts satisfying the same design), each of size $n$, producing $(\hat\theta_{\omega,r})_{r=1}^R$ with
\begin{equation}
\hat\theta_{\omega,r}\mid b_\omega \sim \mathcal{N}(\theta_0+b_\omega,\sigma^2),
\quad r=1,\dots,R.
\end{equation}
A natural journal screen when replications are provided is a meta-analytic (inverse-variance) aggregation. With homoskedastic $\sigma^2$, the pooled estimate is the average
\begin{equation}
\bar\theta_{\omega,R} \equiv \frac{1}{R}\sum_{r=1}^R \hat\theta_{\omega,r},
\qquad
\bar\theta_{\omega,R}\mid b_\omega \sim \mathcal{N}(\theta_0+b_\omega,\sigma^2/R).
\end{equation}
Define the pooled test statistic
\begin{equation}
T_{\omega,R}\equiv \frac{\bar\theta_{\omega,R}}{\sigma/\sqrt{R}}.
\end{equation}
Then
\begin{equation}\label{eq:TR_dist}
T_{\omega,R}\mid b_\omega \sim \mathcal{N}\!\left(\sqrt{R}\frac{\theta_0+b_\omega}{\sigma},\,1\right),
\quad
T_{\omega,R}\sim \mathcal{N}\!\left(\sqrt{R}\frac{\theta_0}{\sigma},\, 1+R\frac{\tau^2}{\sigma^2}\right),
\end{equation}
where the unconditional distribution integrates over $b_\omega\sim \mathcal{N}(0,\tau^2)$.

Replication cost is $c_R>0$ per replication (data acquisition, coordination, implementation).

\subsection{Joint choice of search and replications}
The researcher now chooses $(K,R)$ and submits the maximum pooled statistic across $K$ tried paths, each supported by $R$ replications. Let $p(R)\equiv \Pr(T_{\omega,R}\ge c)$.

From \eqref{eq:TR_dist},
\begin{equation}\label{eq:pR}
p(R)= 1-\Phi\!\left(\frac{c-\sqrt{R}\,\theta_0/\sigma}{\sqrt{1+R\tau^2/\sigma^2}}\right).
\end{equation}
The probability of at least one ``successful'' path is
\begin{equation}
\Pr(T^{\max}_{K,R}\ge c)=1-(1-p(R))^K.
\end{equation}
Expected utility is
\begin{equation}\label{eq:U_KR}
U(K,R)=B\big[1-(1-p(R))^K\big]-c_S K - c_R R.
\end{equation}

\subsection{Optimal number of replications}
For fixed $K$, differentiating \eqref{eq:U_KR} in $R$ yields a simple condition:
\begin{equation}\label{eq:FOC_R_general}
B\cdot K(1-p(R))^{K-1} \cdot p'(R) = c_R,
\end{equation}
where $p'(R)$ is the marginal effect of an additional replication on the probability that a given path clears the threshold.

A closed-form expression for $p'(R)$ follows from \eqref{eq:pR}. Let
\begin{equation}
a(R)\equiv \frac{c-\sqrt{R}\,\theta_0/\sigma}{\sqrt{1+R\tau^2/\sigma^2}}.
\end{equation}
Then $p(R)=1-\Phi(a(R))$ and
\begin{equation}\label{eq:pprime}
p'(R)=\phi(a(R))\cdot\big(-a'(R)\big),
\end{equation}
with $\phi$ the standard normal PDF and
\begin{equation}\label{eq:aprime}
a'(R)=
\frac{-\frac{\theta_0}{2\sigma\sqrt{R}}\sqrt{1+R\tau^2/\sigma^2} - \left(c-\sqrt{R}\,\theta_0/\sigma\right)\frac{\tau^2}{2\sigma^2}\left(1+R\tau^2/\sigma^2\right)^{-1/2}}
{1+R\tau^2/\sigma^2}.
\end{equation}

\begin{proposition}[Privately optimal replications]\label{prop:Rstar}
Fix $K\ge 1$ and suppose $U(K,R)$ is concave in $R$ on $\mathbb{R}_+$. The privately optimal replication count $R^*(K)$ is characterized by the first-order condition
\begin{equation}
B\cdot K(1-p(R^*))^{K-1}\cdot \phi(a(R^*))\cdot\big(-a'(R^*)\big)=c_R,
\end{equation}
with $p(\cdot)$ and $a(\cdot)$ as in \eqref{eq:pR}. In particular, $R^*(K)$ is (weakly) decreasing in $c_R$ and increasing in $B$.
\end{proposition}

\begin{remark}[Replication as a substitute or complement to specification search]
Because $K$ and $R$ both enter through the success probability $1-(1-p(R))^K$, a reduction in $c_S$ (cheaper search) tends to increase optimal $K$ and, through the $(1-p(R))^{K-1}$ term in \eqref{eq:FOC_R_general}, may reduce the marginal value of $R$ (replications become less necessary to obtain at least one significant result). Thus cheaper search can crowd out replication even as it increases publication success---a channel consistent with concerns that technological progress can amplify selection while reducing credibility, absent institutional constraints \citep{GelmanLoken2014, AndrewsKasy2019}. See also mechanism-design approaches that alter the information environment to screen specification mining \citep{EcheniqueHe2021}.
\end{remark}

\subsection{Endogenizing $K$}
The joint optimum $(K^*,R^*)$ solves
\begin{equation}
(K^*,R^*) \in \arg\max_{K\in\mathbb{N},\,R\in\mathbb{N}} U(K,R).
\end{equation}
A convenient approach is: (i) for each $R$, compute $K^*(R)$ as in Proposition \ref{prop:Kstar} with $p=p(R)$; (ii) select $R$ maximizing $U(K^*(R),R)$.
This delivers a tractable mapping from (a) search costs $c_S$, (b) replication costs $c_R$, (c) selection threshold $c$, and (d) the ``reasonable set'' dispersion $\tau^2$.

\section{Connections and extensions}

\paragraph{Relation to the literature.}
The model combines (i) specification uncertainty and search emphasized by \citet{Leamer1978} and the ``garden of forking paths'' argument \citep{GelmanLoken2014} with (ii) selective publication \citep{AndrewsKasy2019} and empirical evidence on p-hacking and selection on significance in economics \citep{BrodeurCookHeyes2020}. The mechanism-design perspective that treats research communication as an incentive problem is developed in \citet{Spiess2025} and in screening approaches such as \citet{EcheniqueHe2021}. Evidence on editorial objectives is consistent with acceptance depending on perceived quality and impact beyond significance \citep{CardDellaVigna2020}.

\paragraph{Alternative acceptance rules and ``replication requirements.''}
A journal could require either (a) pooled significance as above, (b) significance in at least $m$ out of $R$ replications, or (c) a robustness criterion over $\Omega$ (specification curves / multiverse reporting).
These modifications typically preserve the structure of \eqref{eq:U_KR} with $p(R)$ replaced by an appropriate power function, shifting the optimal $R$ and potentially reversing comparative statics when replications reduce the value of opportunistic selection.

\paragraph{Calibration.}
The primitives $(B,c,c_S,c_R,\tau,\sigma)$ can be disciplined using estimates of selection functions and test-statistic bunching \citep{AndrewsKasy2019, BrodeurCookHeyes2020}. In particular, observed distortions in the distribution of reported $t$-statistics can inform $(B/c_S)$ and $\tau/\sigma$, while replication datasets or meta-studies can identify publication probabilities as a function of results \citep{AndrewsKasy2019}.

